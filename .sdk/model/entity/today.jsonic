# Entity: today

main: kit: entity: today: {

  alias: field: {}

  fields: [
    {
      name: "description"
      req: false
      type: "`$STRING`"
    }
    {
      name: "title"
      req: false
      type: "`$STRING`"
    }
  ]

  name: "today"
  op: {
    list: {
      name: "list"
